              <dt className="text-4xl font-bold text-blue-600">{stat.value}</dt>
              <dd className="mt-1 text-sm text-gray-500">{stat.label}</dd>
            </div>
          ))}
        </dl>

        {/* Testimonial cards */}
        <div className="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-6 sm:grid-cols-2 lg:max-w-none lg:grid-cols-3">
          {TESTIMONIALS.map((t) => (
            <figure key={t.author} className="rounded-2xl bg-white p-8 shadow-sm ring-1 ring-gray-200">
              <blockquote className="text-gray-700">
                <p>"{t.quote}"</p>
              </blockquote>
              <figcaption className="mt-6 flex items-center gap-x-4">
                <Image src={t.avatar} alt={t.author} width={40} height={40} className="rounded-full" />
                <div>
                  <div className="font-semibold text-gray-900">{t.author}</div>
                  <div className="text-sm text-gray-500">{t.role}</div>
                </div>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  );
}
```

## SEO Metadata Pattern

```typescript
// app/layout.tsx
import type { Metadata } from 'next';

export const metadata: Metadata = {
  title: {
    template: '%s | YourProduct',
    default: 'YourProduct — Ship SaaS 10x Faster',
  },
  description: 'Production-ready Next.js boilerplate with auth, payments, and analytics built in. Launch your SaaS in days, not weeks.',
  keywords: ['nextjs', 'saas', 'boilerplate', 'starter', 'template'],
  authors: [{ name: 'Your Name', url: 'https://yoursite.com' }],
  openGraph: {
    type: 'website',
    locale: 'en_US',
    url: 'https://yourproduct.com',
    siteName: 'YourProduct',
    title: 'YourProduct — Ship SaaS 10x Faster',
    description: 'Production-ready Next.js boilerplate...',
    images: [{ url: '/og-image.png', width: 1200, height: 630 }],
  },
  twitter: {
    card: 'summary_large_image',
    title: 'YourProduct',
    description: 'Production-ready Next.js boilerplate...',
    images: ['/og-image.png'],
    creator: '@yourhandle',
  },
  robots: {
    index: true,
    follow: true,
    googleBot: {
      index: true,
      follow: true,
      'max-video-preview': -1,
      'max-image-preview': 'large',
      'max-snippet': -1,
    },
  },
};
```

## Performance Optimization

```tsx
// Optimized Image usage
import Image from 'next/image';

// Hero image — above fold, high priority
<Image
  src="/hero.png"
  alt="Product screenshot showing dashboard"
  width={1200}
  height={800}
  priority           // LCP image — load immediately
  className="rounded-lg shadow-2xl"
/>

// Below-fold images — lazy load by default
<Image
  src="/feature-screenshot.png"
  alt="Feature screenshot"
  width={600}
  height={400}
  // no priority — lazy by default
/>
```

## FAQ Accordion Pattern

```tsx
// components/sections/FAQ.tsx
'use client';
import { useState } from 'react';
import { ChevronDown } from 'lucide-react';

const FAQS = [
  { q: 'Is there a free trial?', a: 'No free trial, but we offer a 30-day money-back guarantee.' },
  { q: 'What\'s included in the one-time payment?', a: 'Lifetime access to the template and all future updates.' },
];

export function FAQ() {
  const [openIndex, setOpenIndex] = useState<number | null>(null);

  return (
    <section id="faq" className="py-24">
      <div className="mx-auto max-w-3xl px-6">
        <h2 className="text-3xl font-bold text-center text-gray-900 mb-12">
          Frequently Asked Questions
        </h2>
        <dl className="divide-y divide-gray-200">
          {FAQS.map((faq, index) => (
            <div key={index} className="py-6">
              <dt>
                <button
                  className="flex w-full items-start justify-between text-left"
                  onClick={() => setOpenIndex(openIndex === index ? null : index)}
                  aria-expanded={openIndex === index}
                >
                  <span className="text-lg font-semibold text-gray-900">{faq.q}</span>
                  <ChevronDown
                    className={`ml-6 h-6 w-6 text-gray-400 transition-transform ${openIndex === index ? 'rotate-180' : ''}`}
                  />
                </button>
              </dt>
              {openIndex === index && (
                <dd className="mt-3 text-gray-600">{faq.a}</dd>
              )}
            </div>
          ))}
        </dl>
      </div>
    </section>
  );
}
```

