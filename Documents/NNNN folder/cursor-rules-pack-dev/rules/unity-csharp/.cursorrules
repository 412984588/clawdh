You are an expert in Unity 2022+, C#, game development patterns, Unity ECS/DOTS, and performance optimization for games.

# Project Type
This is a Unity 3D/2D game project using C#, Unity's component system, and modern Unity practices.

## Tech Stack
- Unity 2022.3 LTS or Unity 6
- C# 10+
- Unity Input System (new)
- Universal Render Pipeline (URP) or HDRP
- Unity Addressables for asset management
- DOTween for animations
- Cinemachine for camera

## Code Style and Structure

- Follow C# naming conventions: PascalCase for classes/methods/properties, camelCase for local variables, _camelCase for private fields
- Use `[SerializeField]` for inspector-exposed private fields
- Inherit from appropriate Unity base classes (MonoBehaviour, ScriptableObject)
- Separate concerns: GameManager, UIManager, AudioManager as singletons
- Use events and delegates for decoupled communication
- Cache component references in Awake, use them in Update
- Minimize allocations in Update() — avoid LINQ, new(), string concatenation

## MonoBehaviour Patterns

```csharp
// Scripts/Player/PlayerController.cs
using UnityEngine;
using UnityEngine.InputSystem;

/// <summary>
/// 玩家控制器 — 处理移动和跳跃输入
/// </summary>
[RequireComponent(typeof(Rigidbody2D), typeof(Animator))]
public class PlayerController : MonoBehaviour
{
    [Header("移动参数")]
    [SerializeField] private float moveSpeed = 5f;
    [SerializeField] private float jumpForce = 10f;
    [SerializeField] private LayerMask groundLayer;

    [Header("引用")]
    [SerializeField] private Transform groundCheck;

    // 私有状态
    private Rigidbody2D _rb;
    private Animator _animator;
    private Vector2 _moveInput;
    private bool _isGrounded;

    // 动画参数 ID（缓存 hash，避免字符串查找）
    private static readonly int IsRunning = Animator.StringToHash("IsRunning");
    private static readonly int IsGrounded = Animator.StringToHash("IsGrounded");
    private static readonly int JumpTrigger = Animator.StringToHash("Jump");

    private void Awake()
    {
        // 在 Awake 中缓存所有组件引用
        _rb = GetComponent<Rigidbody2D>();
        _animator = GetComponent<Animator>();
    }

    private void Update()
    {
        // 避免在 Update 中分配内存
        _isGrounded = Physics2D.OverlapCircle(groundCheck.position, 0.1f, groundLayer);
        _animator.SetBool(IsGrounded, _isGrounded);
        _animator.SetBool(IsRunning, _moveInput.x != 0 && _isGrounded);
    }

    private void FixedUpdate()
    {
        // 物理操作放在 FixedUpdate
        float horizontalVelocity = _moveInput.x * moveSpeed;
        _rb.linearVelocity = new Vector2(horizontalVelocity, _rb.linearVelocity.y);
    }

    // Input System 回调
    public void OnMove(InputAction.CallbackContext context)
    {
        _moveInput = context.ReadValue<Vector2>();
    }

    public void OnJump(InputAction.CallbackContext context)
    {
        if (context.performed && _isGrounded)
        {
            _rb.AddForce(Vector2.up * jumpForce, ForceMode2D.Impulse);
            _animator.SetTrigger(JumpTrigger);
        }
    }
}
```

## ScriptableObject for Data

```csharp
// Scripts/Data/WeaponData.cs
using UnityEngine;

/// <summary>
/// 武器数据 ScriptableObject — 在编辑器中配置，运行时只读
/// </summary>
[CreateAssetMenu(fileName = "WeaponData", menuName = "Game/Weapon Data")]
public class WeaponData : ScriptableObject
{
    [Header("基础属性")]
    public string weaponName;
    [TextArea] public string description;
    public Sprite icon;

    [Header("战斗属性")]
    [Range(1, 100)] public int damage = 10;
    [Range(0.1f, 5f)] public float attackRate = 1f;
    public float range = 2f;

    [Header("音效")]
    public AudioClip attackSound;
    public AudioClip hitSound;
}
```

## Event System Pattern

```csharp
// Scripts/Core/GameEvents.cs
using System;
using UnityEngine;

/// <summary>
/// 全局游戏事件 — 解耦系统间通信
/// </summary>
public static class GameEvents
{
    // 玩家事件
    public static event Action<int> OnPlayerHealthChanged;
    public static event Action OnPlayerDied;
    public static event Action<int> OnScoreChanged;

    // 游戏状态事件
    public static event Action OnGamePaused;
    public static event Action OnGameResumed;
    public static event Action<int> OnLevelCompleted;

    // 触发方法（从事件源调用）
    public static void PlayerHealthChanged(int health) =>
        OnPlayerHealthChanged?.Invoke(health);

    public static void PlayerDied() =>
        OnPlayerDied?.Invoke();

    public static void ScoreChanged(int score) =>
        OnScoreChanged?.Invoke(score);
}

// 使用方式 — 在 Player 中触发
public class Player : MonoBehaviour
{
    private int _health = 100;

    public void TakeDamage(int damage)
    {
        _health = Mathf.Max(0, _health - damage);
        GameEvents.PlayerHealthChanged(_health);

        if (_health <= 0)
            GameEvents.PlayerDied();
    }
}

// 使用方式 — 在 UI 中监听
public class HealthUI : MonoBehaviour
{
    private void OnEnable() => GameEvents.OnPlayerHealthChanged += UpdateHealthBar;
    private void OnDisable() => GameEvents.OnPlayerHealthChanged -= UpdateHealthBar;

    private void UpdateHealthBar(int health)
    {
        // 更新 UI
    }
}
```

## Object Pooling

```csharp
// Scripts/Core/ObjectPool.cs
using System.Collections.Generic;
using UnityEngine;

public class ObjectPool : MonoBehaviour
{
    [SerializeField] private GameObject prefab;
    [SerializeField] private int initialSize = 20;
    private Queue<GameObject> _pool = new();

    private void Awake()
    {
        // 预先填充对象池
        for (int i = 0; i < initialSize; i++)
        {
            var obj = Instantiate(prefab);
            obj.SetActive(false);
            _pool.Enqueue(obj);
        }
    }

    public GameObject Get()
    {
        if (_pool.Count > 0)
        {
            var obj = _pool.Dequeue();
            obj.SetActive(true);
            return obj;
        }
        // 池为空时创建新对象（可选：打警告日志）
        Debug.LogWarning($"[ObjectPool] 池为空，创建新 {prefab.name}");
        return Instantiate(prefab);
    }

    public void Return(GameObject obj)
    {
        obj.SetActive(false);
        _pool.Enqueue(obj);
    }
}
```

## Singleton Pattern

```csharp
// Scripts/Core/Singleton.cs
using UnityEngine;

public class Singleton<T> : MonoBehaviour where T : MonoBehaviour
{
    private static T _instance;

    public static T Instance
    {
        get
        {
            if (_instance == null)
            {
                _instance = FindFirstObjectByType<T>();
                if (_instance == null)
                    Debug.LogError($"[Singleton] {typeof(T).Name} 不存在于场景中");
            }
            return _instance;
        }
    }

    protected virtual void Awake()
    {
        if (_instance != null && _instance != this)
        {
            Debug.LogWarning($"[Singleton] 重复的 {typeof(T).Name}，销毁");
            Destroy(gameObject);
            return;
        }
        _instance = this as T;
        DontDestroyOnLoad(gameObject);
    }
}
```

## State Machine Pattern

```csharp
// Scripts/AI/EnemyStateMachine.cs
public enum EnemyState { Idle, Patrol, Chase, Attack, Dead }

public class EnemyStateMachine : MonoBehaviour
{
    private EnemyState _currentState = EnemyState.Idle;

    private void Update()
    {
        switch (_currentState)
        {
            case EnemyState.Idle: HandleIdle(); break;
            case EnemyState.Patrol: HandlePatrol(); break;
            case EnemyState.Chase: HandleChase(); break;
            case EnemyState.Attack: HandleAttack(); break;
        }
    }

    private void TransitionTo(EnemyState newState)
    {
        OnExitState(_currentState);
        _currentState = newState;
        OnEnterState(_currentState);
    }
}
```

## Performance Optimization

```csharp
// 性能最佳实践

// 1. 缓存 WaitForSeconds — 避免每帧 new
private static readonly WaitForSeconds WaitOneSecond = new WaitForSeconds(1f);

// 2. 缓存 Camera.main
private Camera _mainCamera;
private void Awake() { _mainCamera = Camera.main; }

// 3. 使用 CompareTag 而非 == 比较 tag
if (collision.CompareTag("Enemy")) { }  // 正确
// if (collision.tag == "Enemy") { }    // 避免

// 4. 使用 TryGetComponent 避免 null check
if (TryGetComponent<IDamageable>(out var damageable))
{
    damageable.TakeDamage(damage);
}
```

## File Naming Conventions

- MonoBehaviours: `PascalCase.cs` (e.g., `PlayerController.cs`)
- ScriptableObjects: `[Name]Data.cs` or `[Name]Config.cs`
- Interfaces: `I[Name].cs` (e.g., `IDamageable.cs`)
- Enums: `[Name]Type.cs` or within relevant class
- Editor scripts: placed in `Editor/` folder

## What Cursor Should Do

- Cache component references in Awake, not in Update
- Use `[SerializeField]` instead of `public` for inspector fields
- Use `[Header("")]` to organize inspector properties
- Generate `RequireComponent` attributes for dependencies
- Cache `Animator.StringToHash()` in static readonly fields
- Use events for UI updates to decouple systems
- Suggest object pooling for frequently spawned objects

## What Cursor Should Avoid

- Do NOT use `FindObjectOfType` in Update — cache in Awake
- Do NOT use `string` comparisons for tags — use CompareTag
- Do NOT allocate memory in Update (new, LINQ, ToString)
- Do NOT use `public` fields — use `[SerializeField] private`
- Do NOT do heavy calculations in Update — use coroutines or events
- Do NOT forget to unsubscribe from events in OnDisable/OnDestroy
