152],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#现在开始处理用户的请求，一步一步来。执行工具前，先确认工具支持的环境。严谨是第一位的，没有合适工具，直接返回，不做猜测。":[153,160],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#现在开始处理用户的请求，一步一步来。执行工具前，先确认工具支持的环境。严谨是第一位的，没有合适工具，直接返回，不做猜测。#{1}":[157,160],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#基本信息":[161,166],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#基本信息#工具平台：kbt":[162,162],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#基本信息#运行环境：线下、预发":[163,163],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#基本信息#作者：":[164,166],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#功能信息":[167,174],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#功能信息#功能描述：":[168,168],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#功能信息#使用说明：":[169,171],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#功能信息#使用说明：#预发环境：":[170,170],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#功能信息#使用说明：#线下环境：":[171,171],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#功能信息#特殊说明：":[172,174],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#出参信息":[175,177],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#排查辅助":[178,416],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#排查辅助#异常说明：":[179,179],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#排查辅助#排查工具：":[180,180],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#排查辅助#替换方案：":[181,416],"#【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀#排查辅助#替换方案：#{1}":[183,416]},"outlinks":[{"title":"点击查看","target":"https://mp.weixin.qq.com/s/J9Zg4_D6SHkHVq6u8Wd56w","line":14}],"metadata":{"title":"【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀","source":"wechat","url":"https://mp.weixin.qq.com/s/J9Zg4_D6SHkHVq6u8Wd56w","author":"阿里云开发者","pub_date":"2025年10月16日 20:31","created":"2026-01-17 22:23","tags":["#AI","#产品"]},"task_lines":[],"last_embed":{"hash":"1d633si","at":1768845387326}},"smart_blocks:微信文章/【智造】AI应用实战：6个agent搞定复杂指令和工具膨胀.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.06657424,-0.02792855,0.01161326,-0.04092394,0.00004322,0.01171545,0.01514184,0.02038188,0.02780349,-0.00954365,0.05575427,-0.04352029,0.01355169,0.03989995,0.0090403,0.04066418,0.02161274,-0.04854987,-0.04104357,-0.02977816,0.09344519,-0.03156301,0.03995783,-0.07581201,0.00497816,0.02497807,0.0317708,-0.02041472,0.02833307,-0.13452882,-0.01405269,0.0096298,0.08244209,0.01708968,0.003135