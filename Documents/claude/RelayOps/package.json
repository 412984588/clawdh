{
  "name": "relayops",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:public": "playwright test --project=public",
    "test:e2e:admin": "playwright test --project=admin",
    "test:e2e:partner": "playwright test --project=partner",
    "test:e2e:worker": "playwright test --project=worker",
    "test:e2e:report": "playwright show-report",
    "stripe:setup": "node --env-file=.env.local --import tsx/esm scripts/stripe-setup.ts",
    "stripe:pay": "node --env-file=.env.local --import tsx/esm scripts/stripe-pay-test.ts",
    "email:test": "node --env-file=.env.local --import tsx/esm scripts/email-test.ts",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "analyze": "ANALYZE=true next build",
    "validate": "pnpm typecheck && pnpm lint && pnpm test",
    "test:load": "k6 run load-tests/load.js",
    "test:load:smoke": "k6 run load-tests/smoke.js",
    "test:load:stress": "k6 run load-tests/stress.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.7",
    "@sentry/nextjs": "^10.45.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.469.0",
    "mixpanel": "^0.20.0",
    "next": "^15.1.0",
    "next-intl": "^4.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "resend": "^4.0.1",
    "stripe": "^17.5.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@next/bundle-analyzer": "^16.1.7",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^26.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
