# ──────────────────────────────────────────────────────────────────────────────
# RelayOps — Local Development Environment
# Copy this file to .env.local and fill in the values.
#
# Legend:  [REQUIRED]  Must be set for the app to start
#          [LIVE]      Only needed when INTEGRATION_MODE=live
#          [OPTIONAL]  Enhances functionality but not required
# ──────────────────────────────────────────────────────────────────────────────

# ── Integration Mode ─────────────────────────────────────────────────── [REQUIRED]
# "mock"  → Stripe/email/analytics return mock responses (no real charges/emails)
# "live"  → Uses real Stripe, Resend, and analytics credentials
# WARNING: Production MUST be "live" — deploying "mock" to prod will throw a fatal error
INTEGRATION_MODE=mock

# ── Supabase ─────────────────────────────────────────────────────────── [REQUIRED]
# After running `npx supabase start`, get these from:
#   npx supabase status --output json
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────────────────── [LIVE]
# Dashboard → Developers → API keys (use test mode keys for staging)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Resend (email) ───────────────────────────────────────────────────── [LIVE]
RESEND_API_KEY=re_...
EMAIL_FROM=RelayOps <noreply@relayops.com>

# ── Cron ─────────────────────────────────────────────────────────────── [LIVE]
# Bearer token for /api/cron/* endpoints — set a random string (e.g. openssl rand -hex 32)
# Vercel Cron uses this to authenticate scheduled job requests
CRON_SECRET=

# ── Admin Notifications ──────────────────────────────────────────────── [LIVE]
# Email address for SLA alerts and system notifications
ADMIN_NOTIFICATION_EMAIL=

# ── Analytics ────────────────────────────────────────────────────────── [OPTIONAL]
# Mixpanel project token (from mixpanel.com → Settings → Project Token)
# Leave blank to disable analytics tracking
MIXPANEL_TOKEN=

# ── Sentry (error monitoring) ────────────────────────────────────────── [OPTIONAL]
# Leave blank to disable error monitoring
# Client-side DSN (exposed to browser — used by React error boundaries)
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN (used by server actions, cron routes, API routes)
SENTRY_DSN=

# ── App ──────────────────────────────────────────────────────────────── [REQUIRED]
# Production: set to your actual domain (e.g. https://app.relayops.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
