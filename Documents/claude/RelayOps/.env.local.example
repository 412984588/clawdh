# ──────────────────────────────────────────────────────────────────────────────
# RelayOps — Local Development Environment
# Copy this file to .env.local and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# Integration Mode
# "mock"  → Stripe and email calls return mock responses (no real charges/emails)
# "live"  → Uses real Stripe and Resend credentials
INTEGRATION_MODE=mock

# ── Supabase ──────────────────────────────────────────────────────────────────
# After running `npx supabase start`, get these from:
#   npx supabase status --output json
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (only needed for INTEGRATION_MODE=live) ───────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Resend (only needed for INTEGRATION_MODE=live) ───────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=RelayOps <noreply@relayops.com>

# ── Cron (only needed for INTEGRATION_MODE=live) ─────────────────────────────
CRON_SECRET=

# ── Analytics (optional — leave blank in mock mode) ───────────────────────────
# Mixpanel project token (from mixpanel.com → Settings → Project Token)
MIXPANEL_TOKEN=

# ── Sentry (optional — leave blank to disable error monitoring) ───────────────
# Client-side DSN (exposed to browser)
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN (used by server actions, cron routes, API routes)
SENTRY_DSN=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
