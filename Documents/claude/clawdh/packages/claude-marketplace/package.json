{
  "name": "@voice-hub/claude-marketplace",
  "version": "0.2.0",
  "type": "module",
  "description": "Claude Code Marketplace 集成",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    ".claude-plugin",
    ".claude",
    "skills",
    "bin",
    "local-marketplace.json"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier -w src"
  },
  "dependencies": {
    "@voice-hub/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
