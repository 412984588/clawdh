{
  "version": "1.0",
  "auto_confirm_threshold": "T1",
  "rules": [
    {
      "name": "auto_confirm_safe_cleanup",
      "enabled": true,
      "priority": 1,
      "conditions": {
        "safe_cleanup_patterns": [
          "删除.*备份",
          "删除.*无效",
          "清理.*备份",
          "清理.*无效",
          "rm -rf .*-backup",
          "rm -rf .*bak",
          "rm.*\\.backup"
        ],
        "no_dangerous_targets": [
          "数据库",
          "认证",
          "支付",
          "生产环境",
          "核心代码"
        ],
        "require_explicit_permission": true
      },
      "action": "auto_confirm_as_yes"
    },
    {
      "name": "auto_confirm_trivial_tasks",
      "enabled": true,
      "priority": 2,
      "conditions": {
        "task_complexity": [
          "T1"
        ],
        "estimated_lines": "< 20",
        "no_risk_keywords": [
          "数据库",
          "认证",
          "支付",
          "部署",
          "迁移",
          "删除",
          "重构",
          "架构"
        ],
        "user_explicit_confirm": false,
        "require_review": true
      },
      "action": "auto_confirm_as_yes"
    },
    {
      "name": "require_confirm_complex_tasks",
      "enabled": true,
      "priority": 3,
      "conditions": {
        "task_complexity": [
          "T2",
          "T3",
          "T4"
        ],
        "has_risk_keywords": true
      },
      "action": "require_user_confirmation"
    }
  ],
  "risk_keywords": [
    "数据库",
    "认证",
    "支付",
    "删除",
    "部署",
    "迁移",
    "重构",
    "架构",
    "核心",
    "系统",
    "基础设施",
    "rm -rf",
    "DROP",
    "DELETE",
    "TRUNCATE",
    "生产环境",
    "敏感数据"
  ]
}