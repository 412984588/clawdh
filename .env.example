# ===============================================
# Voice Hub - Environment Configuration
# ===============================================
# 这是一个 BYOK (Bring Your Own Key) 项目
# 本仓库不包含任何真实密钥，请自行配置

# Discord Bot Configuration
# 必需 - 从 Discord Developer Portal 获取
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here
DISCORD_VOICE_CHANNEL_ID=your_voice_channel_id_here
DISCORD_CLIENT_ID=your_client_id_here

# Provider Selection
# 可选值:
# disabled | local-mock | local-pipeline | volcengine-realtime | openai-realtime | gemini-live | hume-evi | azure-voice-live | qwen-dashscope
VOICE_PROVIDER=local-mock

# Volcengine Realtime
VOLCENGINE_REALTIME_WS_URL=wss://openspeech.bytedance.com/api/v2/asr
VOLCENGINE_APP_ID=your_volcengine_app_id_here
VOLCENGINE_ACCESS_TOKEN=your_volcengine_access_token_here

# Backward-compatible aliases for legacy doubao naming
DOUBAO_REALTIME_WS_URL=
DOUBAO_APP_ID=
DOUBAO_ACCESS_TOKEN=

# OpenAI Realtime
OPENAI_REALTIME_WS_URL=wss://api.openai.com/v1/realtime
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Gemini Live
GEMINI_LIVE_WS_URL=wss://generativelanguage.googleapis.com/ws
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview

# Hume EVI
HUME_EVI_WS_URL=wss://api.hume.ai/v0/evi/chat
HUME_API_KEY=your_hume_api_key_here
HUME_CONFIG_ID=

# Azure Voice Live
AZURE_VOICE_LIVE_WS_URL=wss://your-resource.openai.azure.com/openai/realtime
AZURE_VOICE_LIVE_API_KEY=your_azure_voice_live_api_key_here
AZURE_VOICE_LIVE_DEPLOYMENT=

# Qwen DashScope Realtime
QWEN_REALTIME_WS_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen3-omni-flash-realtime
QWEN_VOICE=Chelsie
QWEN_REGION=intl

# Backend Dispatcher
# 可选 - 用于异步任务分发
BACKEND_DISPATCH_URL=http://localhost:3001/api/callback
BACKEND_TIMEOUT_MS=30000
BACKEND_MAX_RETRIES=3

# Webhook Server
WEBHOOK_PORT=8911
WEBHOOK_SECRET=generate_random_hmac_secret_here
WEBHOOK_PATH=/webhook/openclaw_callback
VOICE_HUB_API_KEY=
WEBHOOK_LEGACY_SECRET_HEADER=false
WEBHOOK_SHADOW_MODE=false

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Memory Bank (SQLite)
# 默认会落到 ~/.voice-hub/voice-hub.db
MEMORY_DB_PATH=
MEMORY_WAL_ENABLED=true
MEMORY_BUSY_TIMEOUT=5000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_PRETTY=false

# Audio Configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_BITS_PER_SAMPLE=16
AUDIO_FRAME_DURATION_MS=100
AUDIO_JITTER_BUFFER_MS=200

# Session Management
SESSION_TIMEOUT_MS=300000
SESSION_MAX_RECONNECT_ATTEMPTS=5
SESSION_RECONNECT_DELAY_MS=2000
PRECISION_MODE_DEFAULT=natural

# OpenClaw Integration
OPENCLAW_PLUGIN_ENABLED=false
OPENCLAW_AGENT_DIR=./data/agents

# Claude Code Integration
CLAUDE_PLUGIN_ENABLED=false
CLAUDE_MARKETPLACE_PATH=./packages/claude-marketplace
